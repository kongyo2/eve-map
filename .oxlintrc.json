{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["react", "typescript", "unicorn", "import"],
  "rules": {
    "no-console": "warn",
    "no-unused-vars": "warn",
    "no-debugger": "error",
    "eqeqeq": "error",
    "typescript/no-explicit-any": "error"
  },
  "ignorePatterns": ["node_modules/", "dist/", ".expo/", "*.config.js", "scripts/"]
}
